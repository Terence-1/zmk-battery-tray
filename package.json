{
  "name": "zmk-battery-tray",
  "version": "1.0.0",
  "description": "System tray application for monitoring ZMK split keyboard battery levels",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "rebuild:native": "npx electron-rebuild -f -w node-hid @resvg/resvg-js",
    "start": "npm run build && npm run rebuild:native && electron .",
    "dev": "tsc && electron .",
    "package": "npm run build && npm run rebuild:native && electron-builder --linux deb --publish never",
    "package:linux": "npm run package",
    "release": "npm run build && npm run rebuild:native && electron-builder --linux deb --publish always"
  },
  "author": {
    "name": "Terence",
    "email": "terence@users.noreply.github.com"
  },
  "license": "MIT",
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron-updater": "^6.8.3",
    "node-hid": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.zmk.battery-tray",
    "productName": "zmk-battery-tray",
    "directories": {
      "output": "release"
    },
    "icon": "build/icons",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Terence-1",
      "repo": "zmk-battery-tray"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Terence <terence@users.noreply.github.com>",
      "icon": "build/icons"
    },
    "deb": {
      "depends": [
        "libusb-1.0-0",
        "libudev1"
      ]
    },
    "npmRebuild": true
  }
}
