{
  "name": "zmk-battery-tray",
  "version": "1.0.0",
  "description": "System tray application for monitoring ZMK split keyboard battery levels",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "rebuild:native": "bunx electron-rebuild -f -w node-hid",
    "start": "bun run build && bun run rebuild:native && electron .",
    "dev": "tsc && bun run rebuild:native && electron .",
    "package": "bun run build && bun run rebuild:native && electron-builder --linux AppImage",
    "package:linux": "bun run package"
  },
  "author": {
    "name": "Terence",
    "email": "terence@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.6.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "node-hid": "^3.0.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.zmk.battery-tray",
    "productName": "ZMK Battery Tray",
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "maintainer": "Terence <terence@users.noreply.github.com>"
    },
    "npmRebuild": false
  }
}
