{
  "name": "zmk-battery-tray",
  "version": "1.0.0",
  "description": "System tray application for monitoring ZMK split keyboard battery levels",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "rebuild:native": "npx electron-rebuild -f -w node-hid",
    "start": "npm run build && npm run rebuild:native && electron .",
    "dev": "tsc && electron .",
    "package": "npm run build && npm run rebuild:native && electron-builder --linux deb --publish never",
    "package:linux": "npm run package"
  },
  "author": {
    "name": "Terence",
    "email": "terence@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "node-hid": "^3.0.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.zmk.battery-tray",
    "productName": "zmk-battery-tray",
    "directories": {
      "output": "release"
    },
    "icon": "assets/icon.png",
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Terence <terence@users.noreply.github.com>",
      "icon": "assets/icon.png"
    },
    "deb": {
      "depends": [
        "libusb-1.0-0",
        "libudev1"
      ]
    },
    "npmRebuild": false
  }
}
