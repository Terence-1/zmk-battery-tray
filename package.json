{
  "name": "zmk-battery-tray",
  "version": "1.0.0",
  "description": "System tray application for monitoring ZMK split keyboard battery levels",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "package": "npm run build && electron-builder",
    "package:linux": "npm run build && electron-builder --linux",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac"
  },
  "author": {
    "name": "Terence",
    "email": "terence@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "node-hid": "^3.0.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.zmk.battery-tray",
    "productName": "ZMK Battery Tray",
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Terence <terence@users.noreply.github.com>"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
